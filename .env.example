# ThesisTrace environment variables (copy to .env; never commit real secrets).
# All secrets load from the environment only — never hardcoded (D7, AD conventions).

# Supabase Postgres 17 async DSN used by SQLAlchemy/asyncpg (backend).
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/postgres

# Separate database for the test suite — REQUIRED for local dev. conftest.py's
# db_session fixture drops every table at teardown; if this isn't set it falls
# back to DATABASE_URL and pytest will wipe your dev database's schema.
TEST_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/postgres_test

# SEC EDGAR fair-access identifying contact, e.g. "ThesisTrace you@example.com" (AD-9).
# Quoted, no parentheses — uv's --env-file parser doesn't handle unquoted spaces/parens.
EDGAR_CONTACT="ThesisTrace you@example.com"

# Tiingo free-tier API key — Altman market price only (AD-11/AD-14, D7 exception).
TIINGO_API_KEY=your-tiingo-key

# LLM API key — FR-12 constrained rewrite, default Anthropic Claude Haiku (AD-21).
LLM_API_KEY=your-llm-key

# Frontend: base URL of the FastAPI backend (Next.js reads NEXT_PUBLIC_* at build/runtime).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
